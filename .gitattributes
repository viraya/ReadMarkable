# Force LF for any file that runs on the reMarkable (BusyBox /bin/sh) or other
# Linux contexts. Without this, Windows checkouts get CRLF and shell scripts
# throw "bad interpreter: No such file or directory" on the device.

*.sh           text eol=lf
*.service      text eol=lf
*.toml         text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf

# On-device tarball contents must always be LF.
installer/on-device/* text eol=lf
packaging/**          text eol=lf
install.sh            text eol=lf
uninstall.sh          text eol=lf

# CMake + C/C++ work fine either way; let git default decide.
